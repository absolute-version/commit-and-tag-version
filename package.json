{
  "name": "commit-and-tag-version",
  "version": "12.7.2",
  "description": "replacement for `npm version` with automatic CHANGELOG generation",
  "bin": {
    "commit-and-tag-version": "bin/cli.js"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "posttest": "npm run lint && npm run format:check",
    "format:base": "prettier \"./**/*.{ts,js}\"",
    "format:fix": "npm run format:base -- --write",
    "format:check": "npm run format:base -- --check",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --exclude 'test/*.integration-test.js'",
    "test:git-integration": "vitest run test/git.integration-test.js",
    "release": "bin/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/absolute-version/commit-and-tag-version.git"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "conventional-changelog",
    "recommended",
    "changelog",
    "automatic",
    "workflow",
    "version",
    "angular",
    "standard"
  ],
  "author": "Ben Coe <ben@npmjs.com>",
  "contributors": [
    "Timothy Jones <timothy.l.jones@gmail.com> (https://github.com/TimothyJones)"
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/absolute-version/commit-and-tag-version/issues"
  },
  "homepage": "https://github.com/absolute-version/commit-and-tag-version#readme",
  "dependencies": {
    "chalk": "^2.4.2",
    "conventional-changelog": "4.0.0",
    "conventional-changelog-config-spec": "2.1.0",
    "conventional-changelog-conventionalcommits": "6.1.0",
    "conventional-recommended-bump": "7.0.1",
    "detect-indent": "^6.1.0",
    "detect-newline": "^3.1.0",
    "dotgitignore": "^2.1.0",
    "fast-xml-parser": "^5.5.6",
    "figures": "^3.2.0",
    "find-up": "^5.0.0",
    "git-semver-tags": "^5.0.1",
    "semver": "^7.7.2",
    "yaml": "^2.6.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-vitest": "^0.5.4",
    "istanbul-lib-instrument": "^6.0.3",
    "pirates": "^4.0.7",
    "prettier": "^3.3.3",
    "shelljs": "^0.10.0",
    "strip-ansi": "^6.0.1",
    "vitest": "^4.1.0"
  }
}
